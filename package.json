  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.4.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.6.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0"
